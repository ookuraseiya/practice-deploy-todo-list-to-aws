{
  "name": "todo-backend",
  "version": "1.0.0",
  "description": "Todo List Backend with Express.js, TypeScript, MySQL",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start:dev": "NODE_ENV=development ts-node src/server.ts",
    "start:prd": "NODE_ENV=production node dist/server.js",
    "dev": "NODE_ENV=development nodemon --exec ts-node src/server.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv-flow": "^4.1.0",
    "express": "^4.18.2",
    "mysql2": "^3.6.0",
    "uid": "^2.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
